##################################################################
#                    C2 COMMUNICATION RULES                      #
##################################################################

# Rule 1: KarstoRat C2 Heartbeat Detection
# Detects periodic beaconing to C2 server
alert tcp $HOME_NET any -> $EXTERNAL_NET 15144 \
  (msg:"KARSTORAT - C2 Heartbeat Detected"; \
  flow:to_server,established; \
  content:"/notify?event=heartbeat"; http_uri; nocase; \
  content:"user=admin"; http_uri; nocase; \
  content:"public_ip="; http_uri; nocase; \
  sid:1000001; rev:1; \
  reference:url,github.com/cyberthint/Detection-Rules; \
  reference:url,cyberthint.io/karstorat-analysis; \
  classtype:trojan-activity; \
  priority:1; \
  metadata:ruleset "KarstoRat", attack_target "Windows", malware_family "KarstoRat";)


