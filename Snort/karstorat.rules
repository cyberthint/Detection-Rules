alert tcp $HOME_NET any -> $EXTERNAL_NET 3071 \
  (msg:"KARSTORAT - Main C2 Panel Access (3071)"; \
  flow:to_server,established; \
  sid:1000009; rev:1; \
  reference:url,github.com/cyberthint/Detection-Rules; \
  reference:url,shodan.io/host/212.227.65.132; \
  classtype:trojan-activity; \
  priority:2; \
  metadata:ruleset "KarstoRat", c2_port "3071";)

# Rule 10: KarstoRat Backup C2 Panel Access (Port 3072)
