##################################################################
#                    SSH ACCESS DETECTION RULES                  #
##################################################################

# Rule 12: KarstoRat SSH Access Detection (Port 22)
# Detects SSH access attempts to C2 server
alert tcp $HOME_NET any -> $EXTERNAL_NET 22 \
  (msg:"KARSTORAT - SSH Access to C2 Server"; \
  flow:to_server,established; \
  dst-ip:212.227.65.132; \
  sid:1000012; rev:1; \
  reference:url,github.com/cyberthint/Detection-Rules; \
  classtype:trojan-activity; \
  priority:2; \
  metadata:ruleset "KarstoRat";)

# Rule 13: KarstoRat Alternative SSH Access (Port 2022)
# Detects alternative SSH access attempts to C2 server
alert tcp $HOME_NET any -> $EXTERNAL_NET 2022 \
  (msg:"KARSTORAT - Alternative SSH Access to C2 Server"; \
  flow:to_server,established; \
  dst-ip:212.227.65.132; \
  sid:1000013; rev:1; \
  reference:url,github.com/cyberthint/Detection-Rules; \
  classtype:trojan-activity; \
  priority:2; \
  metadata:ruleset "KarstoRat";)


##################################################################
#                    EXTERNAL IP LOOKUP RULES                    #
##################################################################

# Rule 14: KarstoRat External IP Lookup
# Detects external IP address retrieval via api.ipify.org
alert tcp $HOME_NET any -> $EXTERNAL_NET 80 \
  (msg:"KARSTORAT - External IP Lookup"; \
  flow:to_server,established; \
  content:"api.ipify.org"; http_host; nocase; \
  sid:1000014; rev:1; \
  reference:url,github.com/cyberthint/Detection-Rules; \
  classtype:trojan-activity; \
  priority:2; \
  metadata:ruleset "KarstoRat";)


##################################################################
#                     RATE LIMIT POLICY RULES                    #
##################################################################

# Rule 15: KarstoRat RateLimit Policy Detection
# Detects servers using the same rate limit policy as C2
alert tcp $HOME_NET any -> $EXTERNAL_NET [3050,4010,443] \
  (msg:"KARSTORAT - RateLimit Policy Detected"; \
  flow:to_server,established; \
  content:"RateLimit-Policy: 100;w=900"; http_header; nocase; \
  sid:1000015; rev:1; \
  reference:url,github.com/cyberthint/Detection-Rules; \
  classtype:trojan-activity; \
  priority:3; \
  metadata:ruleset "KarstoRat";)
