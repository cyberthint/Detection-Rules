#---------------------------------------
# EMAIL INFRASTRUCTURE DETECTION
#---------------------------------------

# Rule 14: Proofpoint Email Servers
alert tcp $HOME_NET any -> $EXTERNAL_NET [25,587,465,993] (
    msg:"SVG PHISHING - Connection to Proofpoint Email Servers";
    flow:to_server,established;
    content:"mx1-us1.ppe-hosted.com" or content:"mx2-us1.ppe-hosted.com" or content:"dispatch-us.ppe-hosted.com";
    nocase;
    sid:10000014;
    rev:1;
    metadata:date "2026-03-12";
    metadata:severity "MEDIUM";
)

# Rule 15: Mailchimp SPF Record
alert tcp $HOME_NET any -> $EXTERNAL_NET any (
    msg:"SVG PHISHING - Mailchimp SPF Record Access";
    flow:to_server,established;
    content:"servers.mcsv.net"; nocase;
    sid:10000015;
    rev:1;
    metadata:date "2026-03-12";
    metadata:severity "MEDIUM";
)

#---------------------------------------
# HTTP PAYLOAD DETECTION
#---------------------------------------

# Rule 16: OwnCloud URL Pattern
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - OwnCloud C2 URL Pattern Detected";
    flow:to_server,established;
    content:"GET"; http_method;
    content:"/owncloud/index.php/s/"; http_uri;
    content:"RRnwnqmP8tTfAri"; http_uri;
    sid:10000016;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1530";
    metadata:severity "CRITICAL";
)

# Rule 17: XOR Key in HTTP Traffic
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - XOR Key Detected in HTTP Traffic";
    flow:to_server,established;
    content:"6795a9a7242893e6ef978723"; nocase;
    sid:10000017;
    rev:1;
    metadata:date "2026-03-12";
    metadata:severity "CRITICAL";
)

# Rule 18: Email Pattern in URL
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - Email Address in URL Detected";
    flow:to_server,established;
    content:"accounting@brifutelectric.com"; nocase;
    sid:10000018;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1566.002";
    metadata:severity "CRITICAL";
)

# Rule 19: Malicious Full URL Pattern
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - Malicious Full URL Pattern Detected";
    flow:to_server,established;
    content:"js.poocheasta.biz.pl"; nocase;
    content:"PlwCVnH5A9@ii"; distance:0;
    content:"accounting@brifutelectric.com"; distance:0;
    sid:10000019;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1566.002";
    metadata:severity "CRITICAL";
)

# Rule 20: SVG File Download Detection
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - SVG File Download with Remittance_Advice Name";
    flow:to_client,established;
    content:"Content-Type|3a| image/svg+xml"; http_header;
    content:"Remittance_Advice"; nocase;
    sid:10000020;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1204.002";
    metadata:severity "HIGH";
)