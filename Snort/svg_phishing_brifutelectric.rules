#---------------------------------------
# SUBDOMAINS - Specific C2 Endpoints
#---------------------------------------

# Rule 4: owncloud subdomain (C2/File Storage)
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - C2 Server owncloud.brifutelectric.com detected";
    flow:to_server,established;
    content:"Host|3a|"; http_header;
    content:"owncloud.brifutelectric.com"; nocase; within:200;
    sid:10000004;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1530";
    metadata:severity "CRITICAL";
)

# Rule 5: mail C2 subdomains
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - Email C2 Subdomain detected";
    flow:to_server,established;
    content:"Host|3a|"; http_header;
    pcre:"/Host\x3a[^\r\n]*(mail-bf1|mail-bf2|mail-al|mail-al2|mail-fl1)\.brifutelectric\.com/";
    sid:10000005;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1071.001";
    metadata:severity "HIGH";
)

# Rule 6: Cisco network infrastructure subdomains
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - Network Infrastructure Subdomain detected";
    flow:to_server,established;
    content:"Host|3a|"; http_header;
    pcre:"/Host\x3a[^\r\n]*(ciscoorlando|ciscosarasota|ciscobirmingham)\.brifutelectric\.com/";
    sid:10000006;
    rev:1;
    metadata:date "2026-03-12";
    metadata:severity "HIGH";
)

