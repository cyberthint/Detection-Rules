# Rule 1: brifutelectric.com domain traffic
alert tcp $HOME_NET any -> $EXTERNAL_NET $HTTP_PORTS (
    msg:"SVG PHISHING - C2 Domain brifutelectric.com detected";
    flow:to_server,established;
    content:"Host|3a|"; http_header;
    content:"brifutelectric.com"; nocase; within:200;
    sid:10000001;
    rev:1;
    metadata:date "2026-03-12";
    metadata:mitre_attack "T1071.001, T1102";
    metadata:severity "CRITICAL";
    metadata:reference "https://blog.seccops.com/svg-phishing-analysis";
    metadata:hash_md5 "e3b5a03fac7092fa61129ab6d97cd20a";
    metadata:hash_sha256 "4d98123fe95b1a4a318b28ee13bccf1dc45b3b3222b636341c569193c1425aed";
)

